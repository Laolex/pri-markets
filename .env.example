# ── Pri-Markets — example environment ────────────────────────────────────────
# Copy to `.env` and fill in. Real `.env` / `.env.*` files are gitignored; only
# this `.env.example` template is committed. NEVER commit real keys or mnemonics.

# Live E2E harness (scripts/e2e-live-v2.mjs) — verifies a full token-only auction
# round on Sepolia (encrypted bids → oracle resolve → pool reveal → claim).
#
# HD mnemonic the two bettor wallets derive from (index 1 = Bettor A / creator,
# index 2 = Bettor B; index 0 is the keeper/deployer — do NOT reuse it). Fund both
# derived wallets with a little Sepolia ETH for gas; cUSDC is self-minted.
E2E_MNEMONIC="word1 word2 ... word12"

# Sepolia RPC. A keyed endpoint (Infura/Alchemy) is strongly recommended — public
# nodes rate-limit under the bet flow's request volume. Defaults to publicnode.
E2E_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"

# Optional: reuse an existing accumulating market instead of creating a new one.
# MARKET_ID=76
